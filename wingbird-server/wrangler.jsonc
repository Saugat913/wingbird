{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "wingbird-server",
	"compatibility_date": "2025-08-03",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "./src/index.tsx",
	"d1_databases": [
		{
			"binding": "wingbird_db",
			"database_name": "wingbird_db",
			"database_id": "72954442-1b71-46dc-80ef-df4e1bb1cfbd",
			"migrations_dir": "./migrations"
		}
	],
	"dev": {
		"ip": "0.0.0.0",
		"port": 8787
	}
}